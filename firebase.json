{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "database.rules.json",
      "firebase-rules.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "docs/**",
      "scripts/**",
      "Analytics-V2/**",
      "*.md",
      "package.json",
      "package-lock.json",
      "temp_server.js",
      "framework-poc.html"
    ],
    "headers": [
      {
        "source": "/service-worker.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/version.json",
        "headers": [{ "key": "Cache-Control", "value": "no-store" }]
      },
      {
        "source": "/manifest.json",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "emulators": {
    "functions": { "port": 5001 },
    "hosting": { "port": 5000 },
    "database": { "port": 9000 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
