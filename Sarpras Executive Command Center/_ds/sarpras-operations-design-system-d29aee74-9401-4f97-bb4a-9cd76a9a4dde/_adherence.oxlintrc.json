{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data/**",
              "components/feedback/**",
              "components/layout/**",
              "components/primitives/**",
              "ui_kits/sarpras/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Manrope|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Manrope, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='BarListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|value|color|key|ref|className|style|children)$/]",
        "message": "<BarListItem> doesn't accept that prop. Declared props: name, value, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|tools|hoverable|lead|pad|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, subtitle, tools, hoverable, lead, pad, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|mono|render|key|ref|className|style|children)$/]",
        "message": "<DataTableColumn> doesn't accept that prop. Declared props: key, label, align, mono, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<DataTableColumn> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|hint|action|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, hint, action, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|tone|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, tone, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|severity|key|ref|className|style|children)$/]",
        "message": "<InsightRow> doesn't accept that prop. Declared props: icon, title, description, severity."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightRow'] > JSXAttribute[name.name='severity'] > Literal[value!=/^(?:info|good|warn|crit)$/]",
        "message": "<InsightRow> severity must be one of 'info' | 'good' | 'warn' | 'crit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|deltaDir|caption|spark|sparkTone|tone|boxed|key|ref|className|style|children)$/]",
        "message": "<KPICard> doesn't accept that prop. Declared props: label, value, unit, delta, deltaDir, caption, spark, sparkTone, tone, boxed."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute[name.name='deltaDir'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<KPICard> deltaDir must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute[name.name='sparkTone'] > Literal[value!=/^(?:neutral|accent|green|blue|amber|violet)$/]",
        "message": "<KPICard> sparkTone must be one of 'neutral' | 'accent' | 'green' | 'blue' | 'amber' | 'violet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|alert)$/]",
        "message": "<KPICard> tone must be one of 'default' | 'alert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:crumb|title|lede|actions|key|ref|className|style|children)$/]",
        "message": "<PageHeader> doesn't accept that prop. Declared props: crumb, title, lede, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='RingGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|thickness|tone|label|suffix|style|key|ref|className|style|children)$/]",
        "message": "<RingGauge> doesn't accept that prop. Declared props: value, max, size, thickness, tone, label, suffix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RingGauge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|blue|amber|accent|violet|crit)$/]",
        "message": "<RingGauge> tone must be one of 'green' | 'blue' | 'amber' | 'accent' | 'violet' | 'crit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|width|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: value, onChange, placeholder, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|title|subtitle|action|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: tag, title, subtitle, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:values|width|height|tone|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: values, width, height, tone, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: status, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
