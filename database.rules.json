{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "events": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "false"
    },

    "telegram_deliveries": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "false"
    },

    "notifications": {
      ".write": "false",
      "$recipientId": {
        ".read": "auth.uid === $recipientId || auth.token.role === 'admin' || auth.token.role === 'developer'"
      }
    },

    "notification_deliveries": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "false"
    },

    "push_subscriptions": {
      ".write": "false",
      "$userId": {
        ".read": "auth.uid === $userId || auth.token.role === 'admin' || auth.token.role === 'developer'"
      }
    },

    "notification_state": {
      ".write": "false",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },

    "reminders": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "false",
      ".indexOn": ["fireAt"]
    },

    "pettyCashExpenses": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "pettyCashNors": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "pettyCashCycles": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "pettyCashSettings": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "pettyCashAudit": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },

    "overtimeUnits": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "overtimeEmployees": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "overtimeRates": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "overtimeRateVersions": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "overtimeHolidays": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "overtimeRecords": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "overtimeDailySummary": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "overtimeMonthlySummary": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "overtimeAudit": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },

    "v2_sarpras": {
      "import_sessions": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        ".write": "auth.token.role === 'admin'"
      },
      "import_batches": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        ".write": "auth.token.role === 'admin'"
      },
      "file_storage": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        ".write": "auth.token.role === 'admin'"
      }
    },

    "engineering": {
      "assignments": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer' || auth.token.role === 'engineering_coordinator' || auth.token.role === 'engineering_member'",
        ".indexOn": ["status", "priority", "category"],
        "$assignmentId": {
          ".write": "auth.token.role === 'admin' || auth.token.role === 'developer' || ((auth.token.role === 'engineering_coordinator' || auth.token.role === 'engineering_member') && data.exists() && newData.exists() && data.child('status').val() !== 'verified')",
          ".validate": "newData.hasChildren(['id', 'status'])"
        }
      },
      "notifications": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer' || auth.token.role === 'engineering_coordinator' || auth.token.role === 'engineering_member'",
        ".write": "auth.token.role === 'admin' || auth.token.role === 'developer' || auth.token.role === 'engineering_coordinator' || auth.token.role === 'engineering_member'"
      },
      "settings": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer' || auth.token.role === 'engineering_coordinator' || auth.token.role === 'engineering_member'",
        ".write": "auth.token.role === 'admin' || auth.token.role === 'developer'"
      }
    },

    "gudang": {
      "items": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        "$itemId": {
          ".write": "(auth.token.role === 'admin' || auth.token.role === 'developer') && (!data.exists() || newData.child('itemType').val() === data.child('itemType').val())",
          ".validate": "newData.hasChildren(['itemId', 'name', 'itemType', 'category', 'active', 'normalizedName', 'searchTokens', 'createdAt']) && newData.child('itemId').val() === $itemId"
        }
      },

      "movements": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        "$movementId": {
          ".write": "(auth.token.role === 'admin' || auth.token.role === 'developer') && !data.exists()",
          ".validate": "newData.hasChildren(['movementId', 'itemId', 'type', 'quantityDelta', 'reason', 'actorId', 'createdAt']) && newData.child('movementId').val() === $movementId && newData.child('quantityDelta').isNumber()"
        }
      },

      "assets": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        "$assetId": {
          ".write": "auth.token.role === 'admin' || auth.token.role === 'developer'",
          ".validate": "newData.hasChildren(['assetId', 'itemId', 'identity', 'status', 'createdAt']) && newData.child('assetId').val() === $assetId"
        }
      },

      "assetHistory": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        "$historyId": {
          ".write": "(auth.token.role === 'admin' || auth.token.role === 'developer') && !data.exists()",
          ".validate": "newData.hasChildren(['historyId', 'assetId', 'eventType', 'actorId', 'reason', 'occurredAt']) && newData.child('historyId').val() === $historyId"
        }
      },

      "locations": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        "$locationId": {
          ".write": "auth.token.role === 'admin' || auth.token.role === 'developer'",
          ".validate": "newData.hasChildren(['locationId', 'name', 'createdAt']) && newData.child('locationId').val() === $locationId"
        }
      },

      "departments": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        "$departmentId": {
          ".write": "auth.token.role === 'admin' || auth.token.role === 'developer'",
          ".validate": "newData.hasChildren(['departmentId', 'name', 'createdAt']) && newData.child('departmentId').val() === $departmentId"
        }
      },

      "stockProjection": {
        ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
        "$itemId": {
          ".write": "auth.token.role === 'admin' || auth.token.role === 'developer'",
          ".validate": "newData.hasChildren(['itemId', 'quantity', 'rebuiltAt', 'consistent']) && newData.child('itemId').val() === $itemId && newData.child('quantity').isNumber()"
        }
      }
    }
  }
}
