{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "events": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "false"
    },

    "telegram_deliveries": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "false"
    },

    "notifications": {
      ".write": "false",
      "$recipientId": {
        ".read": "auth.uid === $recipientId || auth.token.role === 'admin' || auth.token.role === 'developer'"
      }
    },

    "notification_deliveries": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "false"
    },

    "push_subscriptions": {
      ".write": "false",
      "$userId": {
        ".read": "auth.uid === $userId || auth.token.role === 'admin' || auth.token.role === 'developer'"
      }
    },

    "reminders": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "false",
      ".indexOn": ["fireAt"]
    },

    "pettyCashExpenses": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "pettyCashNors": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "pettyCashCycles": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "pettyCashSettings": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    },
    "pettyCashAudit": {
      ".read": "auth.token.role === 'admin' || auth.token.role === 'developer'",
      ".write": "auth.token.role === 'admin'"
    }
  }
}
